# ── MongoDB Atlas ─────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/ai_placement_mentor?retryWrites=true&w=majority

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=replace-with-a-random-secret-minimum-32-characters-long
JWT_EXPIRATION=86400000

# ── Groq AI API  (get free key at https://console.groq.com) ──────────────────
GROQ_API_KEY=gsk_your_groq_api_key_here

# ── CORS (comma-separated allowed origins) ───────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost
